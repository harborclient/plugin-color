{
  "name": "@harborclient/plugin-color",
  "type": "module",
  "scripts": {
    "release": "bash scripts/publish.sh",
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "pack": "pnpm build && zip -r color.hcp manifest.json README.md dist",
    "sign": "node --experimental-strip-types scripts/sign.ts",
    "verify": "node --experimental-strip-types scripts/verify.ts"
  },
  "dependencies": {
    "@harborclient/sdk": "^1.1.28"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.8",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  }
}
